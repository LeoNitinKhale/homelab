# Copy to .env and fill in. .env is gitignored — never commit real values.

# Django signing key. Blank falls back to an insecure dev default; set a real
# random value for the Hetzner deployment.
SECRET_KEY=

# 1 for local dev, 0 in production.
DEBUG=1

# Comma-separated hostnames allowed to serve the site (production).
# e.g. ALLOWED_HOSTS=homelab.khale.net
ALLOWED_HOSTS=*

# Core database (durable data: mnemonics, trading, health).
# Local dev defaults to the local homelab role if unset; set explicitly in prod.
DATABASE_URL=postgres://homelab:homelab@localhost:5432/homelab_core

# Ops database (ephemeral: tasks, review state).
OPS_DATABASE_URL=postgres://homelab:homelab@localhost:5432/homelab_ops

# YouTrack — ticket-based development of the mnemonics birth/death instances.
# Used by scripts/youtrack_seed.py. Token is a secret; never commit real values.
YOUTRACK_URL=https://you.youtrack.cloud
YOUTRACK_TOKEN=perm-...
# Project short-name (e.g. MNE) or display name (e.g. Mnemonics).
YOUTRACK_PROJECT=Mnemonics
