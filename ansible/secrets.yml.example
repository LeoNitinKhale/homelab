# Copy to ansible/secrets.yml (gitignored) and fill in real values.
#
# Generate a Django secret key:
#   python -c "from django.core.management.utils import get_random_secret_key as k; print(k())"
django_secret_key: "replace-with-a-50-char-random-secret"

# NOTE: db_password currently lives in inventory.ini (committed). It should be
# moved here and referenced from the Postgres + Deploy plays; the value already
# in git history should be rotated. See docs/DEPLOYMENT.md.
