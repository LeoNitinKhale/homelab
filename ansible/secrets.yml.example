# Copy to ansible/secrets.yml (gitignored) and fill in real values.
# The Postgres play (Play 4) and Deploy play (Play 7) load this via vars_files.

# PostgreSQL password for the `homelab` role (core + ops databases).
db_password: "set-a-strong-password"

# Django secret key. Generate one with:
#   python -c "from django.core.management.utils import get_random_secret_key as k; print(k())"
django_secret_key: "replace-with-a-50-char-random-secret"
